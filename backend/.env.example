# Claude API — required for the AI chatbot feature
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT secret — MUST be changed to a long random string before deploying to production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-change-in-production

# Frontend origin — used for CORS. In production set to your actual domain, e.g. https://santenav.example.com
FRONTEND_URL=http://localhost:3000

# Zipcodebase API — used to resolve postal codes to coordinates
ZIPCODEBASE_API_KEY=your_zipcodebase_api_key_here
